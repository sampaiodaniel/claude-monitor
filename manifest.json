{
  "manifest_version": 3,
  "name": "Claude Monitor",
  "version": "1.1.0",
  "description": "Monitor Claude AI usage limits with threshold alerts",
  "permissions": [
    "alarms",
    "cookies",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
